{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumradar.io/schemas/tick_data.schema.json",
  "title": "TickData",
  "description": "Normalized on-chain tick-data event for QuantumRadar ingestion pipeline. Contract shared by Track 1A/1B/1D and Epic 2 Graph builder. Any change is breaking — bump $id path.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "block_number",
    "block_timestamp",
    "protocol",
    "event_type",
    "pool_address",
    "token0",
    "token1",
    "amount0",
    "amount1",
    "tx_hash",
    "log_index"
  ],
  "properties": {
    "block_number": {
      "type": "integer",
      "minimum": 0,
      "description": "Ethereum block number."
    },
    "block_timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp ending with Z."
    },
    "protocol": {
      "type": "string",
      "enum": ["uniswap_v3", "aave_v3", "aave_v2"],
      "description": "aave_v2 is included for historical backtests (LUNA 2022-05, FTX 2022-11) — Aave V3 mainnet was not deployed until 2023-01-27."
    },
    "event_type": {
      "type": "string",
      "enum": ["swap", "mint", "burn", "borrow", "supply", "withdraw", "liquidation"]
    },
    "pool_address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "description": "Contract address (pool or lending pool)."
    },
    "token0": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "token1": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "amount0": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "maxLength": 80,
      "description": "Decimal string to preserve wei precision. Negative allowed for signed swap deltas. maxLength=80 covers uint256 (78 digits) + optional decimal point + sign."
    },
    "amount1": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "maxLength": 80
    },
    "tx_hash": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "log_index": {
      "type": "integer",
      "minimum": 0
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "protocol": { "const": "uniswap_v3" } }
      },
      "then": {
        "properties": {
          "event_type": { "enum": ["swap", "mint", "burn"] }
        }
      }
    },
    {
      "if": {
        "properties": { "protocol": { "const": "aave_v3" } }
      },
      "then": {
        "properties": {
          "event_type": { "enum": ["borrow", "supply", "withdraw", "liquidation"] }
        }
      }
    },
    {
      "if": {
        "properties": { "protocol": { "const": "aave_v2" } }
      },
      "then": {
        "properties": {
          "event_type": { "enum": ["borrow", "supply", "withdraw", "liquidation"] }
        }
      }
    }
  ]
}
