# QuantumRadar — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real credentials.

# --- REQUIRED ---

# Primary WebSocket RPC endpoint (Alchemy, Infura, or local node)
# Format: wss://eth-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# --- OPTIONAL ---

# Fallback WSS endpoint (used by reconnector if primary fails)
# WSS_FALLBACK_URL=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY_HERE

# Alchemy API key (standalone, if not embedded in WSS_URL)
# ALCHEMY_KEY=YOUR_ALCHEMY_KEY_HERE

# Etherscan API key (used by Story 1E.2 reconciliation tool)
# ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_HERE

# --- DEV / CI ---
# For local development and CI, use mock WSS from Story 0.5:
# WSS_URL=ws://localhost:8546
# Webhook test endpoint (Story E.3)
WEBHOOK_TEST_URL=http://localhost:9000/hook
