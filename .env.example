# Đăng ký tài khoản và lấy WSS URL miễn phí tại: https://dashboard.alchemy.com
WSS_URL=YOUR_ALCHEMY_WSS_URL_HERE

# Bản dự phòng (Infura fallback URL): Đăng ký tại https://infura.io
WSS_FALLBACK_URL=YOUR_INFURA_WSS_URL_HERE

# Đăng ký tài khoản và tạo API Key tại: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# Webhook Test URL phục vụ cấu hình thử nghiệm cho Story E.3 (Placeholder)
# Tạo URL test nhanh tại: https://webhook.site
WEBHOOK_TEST_URL=https://webhook.site/YOUR_DEFAULT_UUID_HERE